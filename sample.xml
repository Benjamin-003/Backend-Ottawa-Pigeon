<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE topic PUBLIC "-//OASIS//DTD DITA Topic//EN" "topic.dtd">
<topic id="sample-topic">
  <title>Guide d'installation</title>
  <shortdesc>Ce document décrit les étapes d'installation du logiciel.</shortdesc>
  <body>
    <section id="prerequisites">
      <title>Prérequis</title>
      <ul>
        <li>Java 11 ou supérieur</li>
        <li>Node.js 18 ou supérieur</li>
        <li>Docker Desktop</li>
      </ul>
    </section>
    <section id="installation">
      <title>Installation</title>
      <steps>
        <step>
          <cmd>Clonez le repository</cmd>
          <info>git clone https://github.com/monrepo.git</info>
        </step>
        <step>
          <cmd>Installez les dépendances</cmd>
          <info>npm install</info>
        </step>
        <step>
          <cmd>Lancez l'application</cmd>
          <info>npm run dev</info>
        </step>
      </steps>
    </section>
    <section id="configuration">
      <title>Configuration</title>
      <p>Créez un fichier <codeph>.env</codeph> à la racine du projet avec les variables suivantes :</p>
      <codeblock>
        PORT=3000
        DATABASE_URL=postgresql://user:password@localhost:5432/mydb
        JWT_SECRET=mon_secret
      </codeblock>
    </section>
  </body>
</topic>